<Application x:Class="DuplicateFinderPro.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:conv="clr-namespace:DuplicateFinderPro.App.Converters">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <materialDesign:BundledTheme BaseTheme="Light"
                                             PrimaryColor="Teal"
                                             SecondaryColor="Green"
                                             ColorAdjustment="{materialDesign:ColorAdjustment}" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesign2.Defaults.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Shared value converters -->
            <conv:ByteSizeConverter x:Key="ByteSize" />
            <conv:InverseBooleanConverter x:Key="InverseBool" />
            <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
            <conv:CountToVisibilityConverter x:Key="CountToVis" />
            <conv:StringToVisibilityConverter x:Key="StringToVis" />
            <conv:UtcToLocalConverter x:Key="UtcToLocal" />
            <conv:ThumbnailConverter x:Key="Thumbnail" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
