<Window x:Class="DuplicateFinderPro.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:loc="clr-namespace:DuplicateFinderPro.App.Localization"
        xmlns:ctrl="clr-namespace:DuplicateFinderPro.App.Controls"
        xmlns:vm="clr-namespace:DuplicateFinderPro.App.ViewModels"
        xmlns:sys="clr-namespace:System;assembly=System.Runtime"
        d:DataContext="{d:DesignInstance vm:MainViewModel}"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        Background="{DynamicResource MaterialDesignPaper}"
        FontFamily="Segoe UI, Tahoma, Vazirmatn"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="Auto"
        FlowDirection="{Binding FlowDirection, Source={x:Static loc:Localization.Instance}}"
        Title="{loc:Loc App.Title}"
        Height="820" Width="1280"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <!-- ===================== Design system ===================== -->
        <LinearGradientBrush x:Key="HeaderGradient" StartPoint="0,0" EndPoint="1,0.4">
            <GradientStop Color="#00897B" Offset="0" />   <!-- teal 600 -->
            <GradientStop Color="#2E7D32" Offset="1" />   <!-- green 800 -->
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="ScanGradient" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#00897B" Offset="0" />
            <GradientStop Color="#43A047" Offset="1" />
        </LinearGradientBrush>
        <SolidColorBrush x:Key="DangerBrush" Color="#E53935" />
        <SolidColorBrush x:Key="WarnBrush" Color="#F59E0B" />

        <!-- Section card -->
        <Style x:Key="Section" TargetType="materialDesign:Card">
            <Setter Property="Padding" Value="18" />
            <Setter Property="Margin" Value="8,7,8,7" />
            <Setter Property="UniformCornerRadius" Value="14" />
            <Setter Property="materialDesign:ElevationAssist.Elevation" Value="Dp2" />
        </Style>

        <!-- Section title with a colored accent bar -->
        <Style x:Key="SectionHeader" TargetType="StackPanel">
            <Setter Property="Orientation" Value="Horizontal" />
            <Setter Property="Margin" Value="0,0,0,12" />
        </Style>
        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15.5" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style x:Key="AccentBar" TargetType="Border">
            <Setter Property="Width" Value="4" />
            <Setter Property="Height" Value="18" />
            <Setter Property="CornerRadius" Value="2" />
            <Setter Property="Margin" Value="0,0,10,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Background" Value="{DynamicResource PrimaryHueMidBrush}" />
        </Style>

        <!-- Stat card in the results summary -->
        <Style x:Key="StatCard" TargetType="Border">
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="14,11" />
            <Setter Property="Margin" Value="5" />
            <Setter Property="MinWidth" Value="150" />
            <Setter Property="Background" Value="{DynamicResource MaterialDesignChipBackground}" />
        </Style>
        <Style x:Key="StatLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Opacity" Value="0.7" />
            <Setter Property="Margin" Value="0,0,0,2" />
        </Style>
        <Style x:Key="StatValue" TargetType="TextBlock">
            <Setter Property="FontSize" Value="22" />
            <Setter Property="FontWeight" Value="Bold" />
        </Style>

        <!-- Prominent primary button (gradient) -->
        <Style x:Key="PrimaryAction" TargetType="Button" BasedOn="{StaticResource MaterialDesignRaisedButton}">
            <Setter Property="Height" Value="48" />
            <Setter Property="Background" Value="{StaticResource ScanGradient}" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="10" />
            <Setter Property="materialDesign:ElevationAssist.Elevation" Value="Dp3" />
        </Style>

        <!-- One horizontal bar in the Statistics charts -->
        <DataTemplate x:Key="StatBarTemplate">
            <Grid Margin="0,5">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <DockPanel Grid.Row="0" Margin="0,0,0,3">
                    <TextBlock DockPanel.Dock="Right" Text="{Binding ValueText}" FontWeight="SemiBold" Opacity="0.85" />
                    <TextBlock Text="{Binding Label}" TextTrimming="CharacterEllipsis" Opacity="0.85" />
                </DockPanel>
                <ProgressBar Grid.Row="1" Height="9" Minimum="0" Maximum="100"
                             Value="{Binding Percent, Mode=OneWay}"
                             Foreground="{Binding Brush}"
                             Background="{DynamicResource MaterialDesignDivider}" />
            </Grid>
        </DataTemplate>
    </Window.Resources>

    <materialDesign:DialogHost Identifier="Root">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- ===== Top app bar ===== -->
            <Border Grid.Row="0" Background="{StaticResource HeaderGradient}"
                    materialDesign:ElevationAssist.Elevation="Dp4" Padding="20,12" TextElement.Foreground="White">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="46" Height="46" CornerRadius="12" Background="#33FFFFFF" VerticalAlignment="Center">
                            <materialDesign:PackIcon Kind="FileFind" Width="26" Height="26"
                                                     HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White" />
                        </Border>
                        <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="{loc:Loc App.Title}" FontSize="19" FontWeight="Bold" Foreground="White" />
                            <TextBlock Text="{loc:Loc App.Subtitle}" FontSize="12" Opacity="0.85" Foreground="White" />
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <Border CornerRadius="20" Background="#26FFFFFF" Padding="3" VerticalAlignment="Center" Margin="0,0,8,0">
                            <StackPanel Orientation="Horizontal">
                                <Button Style="{StaticResource MaterialDesignFlatButton}" Foreground="White" Height="30" Padding="14,0"
                                        materialDesign:ButtonAssist.CornerRadius="16"
                                        Command="{Binding SetLanguageCommand}"
                                        CommandParameter="{x:Static loc:AppLanguage.English}"
                                        Content="{loc:Loc Lang.English}" />
                                <Button Style="{StaticResource MaterialDesignFlatButton}" Foreground="White" Height="30" Padding="14,0"
                                        materialDesign:ButtonAssist.CornerRadius="16"
                                        Command="{Binding SetLanguageCommand}"
                                        CommandParameter="{x:Static loc:AppLanguage.Persian}"
                                        Content="{loc:Loc Lang.Persian}" />
                            </StackPanel>
                        </Border>
                        <Button Style="{StaticResource MaterialDesignIconButton}"
                                Foreground="White"
                                ToolTip="{loc:Loc Menu.Theme}"
                                Command="{Binding ToggleThemeCommand}">
                            <materialDesign:PackIcon Kind="ThemeLightDark" />
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ===== Body ===== -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="400" MinWidth="340" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" MinWidth="480" />
                </Grid.ColumnDefinitions>

                <!-- ===== Left: configuration ===== -->
                <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" Padding="4">
                    <StackPanel>
                        <!-- Folders -->
                        <materialDesign:Card Style="{StaticResource Section}">
                            <StackPanel>
                                <StackPanel Style="{StaticResource SectionHeader}">
                                    <Border Style="{StaticResource AccentBar}" />
                                    <materialDesign:PackIcon Kind="FolderMultipleOutline" VerticalAlignment="Center" Margin="0,0,8,0"
                                                             Foreground="{DynamicResource PrimaryHueMidBrush}" />
                                    <TextBlock Style="{StaticResource SectionTitle}" Text="{loc:Loc Config.Folders}" />
                                </StackPanel>
                                <Border BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="1"
                                        CornerRadius="6" MinHeight="90" AllowDrop="True"
                                        Drop="OnFoldersDrop" DragOver="OnFoldersDragOver">
                                    <Grid>
                                        <TextBlock Text="{loc:Loc Config.DropHint}" Opacity="0.5"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                                   TextWrapping="Wrap" Margin="12"
                                                   Visibility="{Binding Folders.Count, Converter={StaticResource CountToVis}, ConverterParameter=invert}" />
                                        <ItemsControl ItemsSource="{Binding Folders}" Margin="4">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="2">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <materialDesign:PackIcon Grid.Column="0" Kind="Folder"
                                                                                 VerticalAlignment="Center" Margin="4,0" />
                                                        <TextBlock Grid.Column="1" Text="{Binding}" VerticalAlignment="Center"
                                                                   TextTrimming="CharacterEllipsis" ToolTip="{Binding}" />
                                                        <Button Grid.Column="2" Style="{StaticResource MaterialDesignIconButton}"
                                                                Width="28" Height="28" Padding="0"
                                                                Command="{Binding DataContext.RemoveFolderCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                CommandParameter="{Binding}">
                                                            <materialDesign:PackIcon Kind="Close" Width="16" Height="16" />
                                                        </Button>
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Grid>
                                </Border>
                                <Button Margin="0,10,0,0" HorizontalAlignment="Stretch"
                                        Style="{StaticResource MaterialDesignOutlinedButton}"
                                        Command="{Binding AddFolderCommand}">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="FolderPlus" Margin="0,0,6,0" />
                                        <TextBlock Text="{loc:Loc Config.AddFolder}" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </materialDesign:Card>

                        <!-- Detection methods -->
                        <materialDesign:Card Style="{StaticResource Section}">
                            <StackPanel>
                                <StackPanel Style="{StaticResource SectionHeader}">
                                    <Border Style="{StaticResource AccentBar}" />
                                    <materialDesign:PackIcon Kind="MagnifyScan" VerticalAlignment="Center" Margin="0,0,8,0"
                                                             Foreground="{DynamicResource PrimaryHueMidBrush}" />
                                    <TextBlock Style="{StaticResource SectionTitle}" Text="{loc:Loc Config.Methods}" />
                                </StackPanel>
                                <CheckBox IsChecked="{Binding UseExactContent}" Margin="0,5">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="Fingerprint" Width="22" Height="22" Margin="2,1,10,0" VerticalAlignment="Top"
                                                                 Foreground="{DynamicResource PrimaryHueMidBrush}" />
                                        <StackPanel>
                                            <TextBlock Text="{loc:Loc Method.ExactContent}" FontWeight="Medium" />
                                            <TextBlock Text="{loc:Loc Method.ExactContent.Desc}" FontSize="11" Opacity="0.7" TextWrapping="Wrap" />
                                        </StackPanel>
                                    </StackPanel>
                                </CheckBox>
                                <CheckBox IsChecked="{Binding UseNameSimilarity}" Margin="0,5">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="FormTextbox" Width="22" Height="22" Margin="2,1,10,0" VerticalAlignment="Top"
                                                                 Foreground="{DynamicResource PrimaryHueMidBrush}" />
                                        <StackPanel>
                                            <TextBlock Text="{loc:Loc Method.NameSimilarity}" FontWeight="Medium" />
                                            <TextBlock Text="{loc:Loc Method.NameSimilarity.Desc}" FontSize="11" Opacity="0.7" TextWrapping="Wrap" />
                                        </StackPanel>
                                    </StackPanel>
                                </CheckBox>
                                <CheckBox IsChecked="{Binding UsePerceptualImage}" Margin="0,5">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="ImageMultipleOutline" Width="22" Height="22" Margin="2,1,10,0" VerticalAlignment="Top"
                                                                 Foreground="{DynamicResource PrimaryHueMidBrush}" />
                                        <StackPanel>
                                            <TextBlock Text="{loc:Loc Method.PerceptualImage}" FontWeight="Medium" />
                                            <TextBlock Text="{loc:Loc Method.PerceptualImage.Desc}" FontSize="11" Opacity="0.7" TextWrapping="Wrap" />
                                        </StackPanel>
                                    </StackPanel>
                                </CheckBox>
                                <CheckBox IsChecked="{Binding UsePerceptualVideo}" Margin="0,5">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="MovieOpenOutline" Width="22" Height="22" Margin="2,1,10,0" VerticalAlignment="Top"
                                                                 Foreground="{DynamicResource PrimaryHueMidBrush}" />
                                        <StackPanel>
                                            <TextBlock Text="{loc:Loc Method.PerceptualVideo}" FontWeight="Medium" />
                                            <TextBlock Text="{loc:Loc Method.PerceptualVideo.Desc}" FontSize="11" Opacity="0.7" TextWrapping="Wrap" />
                                        </StackPanel>
                                    </StackPanel>
                                </CheckBox>

                                <Separator Margin="0,6" Opacity="0.4" />
                                <CheckBox IsChecked="{Binding AnalyzePhotoQuality}" Margin="0,5">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="ImageSearchOutline" Width="22" Height="22" Margin="2,1,10,0" VerticalAlignment="Top"
                                                                 Foreground="{DynamicResource SecondaryHueMidBrush}" />
                                        <StackPanel>
                                            <TextBlock Text="{loc:Loc Method.PhotoQuality}" FontWeight="Medium" />
                                            <TextBlock Text="{loc:Loc Method.PhotoQuality.Desc}" FontSize="11" Opacity="0.7" TextWrapping="Wrap" />
                                        </StackPanel>
                                    </StackPanel>
                                </CheckBox>
                            </StackPanel>
                        </materialDesign:Card>

                        <!-- Filters -->
                        <materialDesign:Card Style="{StaticResource Section}">
                            <StackPanel>
                                <StackPanel Style="{StaticResource SectionHeader}">
                                    <Border Style="{StaticResource AccentBar}" />
                                    <materialDesign:PackIcon Kind="FilterVariant" VerticalAlignment="Center" Margin="0,0,8,0"
                                                             Foreground="{DynamicResource PrimaryHueMidBrush}" />
                                    <TextBlock Style="{StaticResource SectionTitle}" Text="{loc:Loc Config.Filters}" />
                                </StackPanel>
                                <CheckBox Content="{loc:Loc Config.Recursive}" IsChecked="{Binding Recursive}" Margin="0,2" />
                                <CheckBox Content="{loc:Loc Config.IncludeHidden}" IsChecked="{Binding IncludeHidden}" Margin="0,2" />
                                <TextBox Margin="0,10,0,0"
                                         materialDesign:HintAssist.Hint="{loc:Loc Config.MinSize}"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         Text="{Binding MinSizeKb, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBox Margin="0,10,0,0"
                                         materialDesign:HintAssist.Hint="{loc:Loc Config.MaxSize}"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         Text="{Binding MaxSizeKb, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBox Margin="0,10,0,0"
                                         materialDesign:HintAssist.Hint="{loc:Loc Config.IncludeExt}"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         Text="{Binding IncludeExtensions, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBox Margin="0,10,0,0"
                                         materialDesign:HintAssist.Hint="{loc:Loc Config.ExcludeExt}"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         Text="{Binding ExcludeExtensions, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                        </materialDesign:Card>

                        <!-- Advanced -->
                        <materialDesign:Card Style="{StaticResource Section}">
                            <StackPanel>
                                <StackPanel Style="{StaticResource SectionHeader}">
                                    <Border Style="{StaticResource AccentBar}" />
                                    <materialDesign:PackIcon Kind="Tune" VerticalAlignment="Center" Margin="0,0,8,0"
                                                             Foreground="{DynamicResource PrimaryHueMidBrush}" />
                                    <TextBlock Style="{StaticResource SectionTitle}" Text="{loc:Loc Config.Advanced}" />
                                </StackPanel>

                                <!-- Name matching -->
                                <StackPanel Margin="0,4,0,0">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="FormTextbox" VerticalAlignment="Center" Margin="0,0,6,0"
                                                                 Foreground="{DynamicResource PrimaryHueMidBrush}" />
                                        <TextBlock Text="{loc:Loc Adv.NameSection}" FontWeight="Medium" VerticalAlignment="Center" />
                                    </StackPanel>
                                    <TextBlock Text="{loc:Loc Adv.EnableHint}" FontSize="11" FontStyle="Italic" Opacity="0.7" TextWrapping="Wrap" Margin="0,2,0,0"
                                               Foreground="{DynamicResource PrimaryHueMidBrush}"
                                               Visibility="{Binding UseNameSimilarity, Converter={StaticResource BoolToVis}, ConverterParameter=invert}" />
                                    <StackPanel IsEnabled="{Binding UseNameSimilarity}">
                                        <TextBlock Text="{loc:Loc Adv.NameDesc}" FontSize="11" Opacity="0.6" TextWrapping="Wrap" Margin="0,2,0,2" />
                                        <StackPanel Orientation="Horizontal" Margin="0,1">
                                            <materialDesign:PackIcon Kind="CheckCircleOutline" Width="14" Height="14" VerticalAlignment="Center" Margin="0,0,4,0" Foreground="{DynamicResource SecondaryHueMidBrush}" />
                                            <TextBlock Text="{loc:Loc Adv.NamePro}" FontSize="11" Opacity="0.75" TextWrapping="Wrap" />
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,1,0,4">
                                            <materialDesign:PackIcon Kind="AlertCircleOutline" Width="14" Height="14" VerticalAlignment="Center" Margin="0,0,4,0" Foreground="#FFB300" />
                                            <TextBlock Text="{loc:Loc Adv.NameCon}" FontSize="11" Opacity="0.75" TextWrapping="Wrap" />
                                        </StackPanel>
                                        <DockPanel>
                                            <TextBlock DockPanel.Dock="Right" MinWidth="46" TextAlignment="Center"
                                                       Text="{Binding NameThreshold, StringFormat={}{0:P0}}" VerticalAlignment="Center" />
                                            <Slider Minimum="0.5" Maximum="1.0" TickFrequency="0.05" IsSnapToTickEnabled="True"
                                                    ToolTip="{loc:Loc Config.NameThreshold}"
                                                    Value="{Binding NameThreshold}" Margin="0,0,8,0" />
                                        </DockPanel>
                                    </StackPanel>
                                </StackPanel>

                                <Separator Margin="0,10" Opacity="0.4" />

                                <!-- Images -->
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="ImageMultipleOutline" VerticalAlignment="Center" Margin="0,0,6,0"
                                                                 Foreground="{DynamicResource PrimaryHueMidBrush}" />
                                        <TextBlock Text="{loc:Loc Adv.ImageSection}" FontWeight="Medium" VerticalAlignment="Center" />
                                    </StackPanel>
                                    <TextBlock Text="{loc:Loc Adv.EnableHint}" FontSize="11" FontStyle="Italic" Opacity="0.7" TextWrapping="Wrap" Margin="0,2,0,0"
                                               Foreground="{DynamicResource PrimaryHueMidBrush}"
                                               Visibility="{Binding UsePerceptualImage, Converter={StaticResource BoolToVis}, ConverterParameter=invert}" />
                                    <StackPanel IsEnabled="{Binding UsePerceptualImage}">
                                        <TextBlock Text="{loc:Loc Adv.ImageDesc}" FontSize="11" Opacity="0.6" TextWrapping="Wrap" Margin="0,2,0,2" />
                                        <StackPanel Orientation="Horizontal" Margin="0,1">
                                            <materialDesign:PackIcon Kind="CheckCircleOutline" Width="14" Height="14" VerticalAlignment="Center" Margin="0,0,4,0" Foreground="{DynamicResource SecondaryHueMidBrush}" />
                                            <TextBlock Text="{loc:Loc Adv.ImagePro}" FontSize="11" Opacity="0.75" TextWrapping="Wrap" />
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,1,0,4">
                                            <materialDesign:PackIcon Kind="AlertCircleOutline" Width="14" Height="14" VerticalAlignment="Center" Margin="0,0,4,0" Foreground="#FFB300" />
                                            <TextBlock Text="{loc:Loc Adv.ImageCon}" FontSize="11" Opacity="0.75" TextWrapping="Wrap" />
                                        </StackPanel>
                                        <DockPanel>
                                            <TextBlock DockPanel.Dock="Right" MinWidth="46" TextAlignment="Center"
                                                       Text="{Binding PerceptualThreshold}" VerticalAlignment="Center" />
                                            <Slider Minimum="0" Maximum="32" TickFrequency="1" IsSnapToTickEnabled="True"
                                                    ToolTip="{loc:Loc Config.PerceptualThreshold}"
                                                    Value="{Binding PerceptualThreshold}" Margin="0,0,8,0" />
                                        </DockPanel>
                                    </StackPanel>
                                </StackPanel>

                                <Separator Margin="0,10" Opacity="0.4" />

                                <!-- Videos -->
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="MovieOpenOutline" VerticalAlignment="Center" Margin="0,0,6,0"
                                                                 Foreground="{DynamicResource PrimaryHueMidBrush}" />
                                        <TextBlock Text="{loc:Loc Adv.VideoSection}" FontWeight="Medium" VerticalAlignment="Center" />
                                    </StackPanel>
                                    <TextBlock Text="{loc:Loc Adv.EnableHint}" FontSize="11" FontStyle="Italic" Opacity="0.7" TextWrapping="Wrap" Margin="0,2,0,0"
                                               Foreground="{DynamicResource PrimaryHueMidBrush}"
                                               Visibility="{Binding UsePerceptualVideo, Converter={StaticResource BoolToVis}, ConverterParameter=invert}" />
                                    <StackPanel IsEnabled="{Binding UsePerceptualVideo}">
                                        <TextBlock Text="{loc:Loc Adv.VideoDesc}" FontSize="11" Opacity="0.6" TextWrapping="Wrap" Margin="0,2,0,2" />
                                        <StackPanel Orientation="Horizontal" Margin="0,1">
                                            <materialDesign:PackIcon Kind="CheckCircleOutline" Width="14" Height="14" VerticalAlignment="Center" Margin="0,0,4,0" Foreground="{DynamicResource SecondaryHueMidBrush}" />
                                            <TextBlock Text="{loc:Loc Adv.VideoPro}" FontSize="11" Opacity="0.75" TextWrapping="Wrap" />
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,1,0,4">
                                            <materialDesign:PackIcon Kind="AlertCircleOutline" Width="14" Height="14" VerticalAlignment="Center" Margin="0,0,4,0" Foreground="#FFB300" />
                                            <TextBlock Text="{loc:Loc Adv.VideoCon}" FontSize="11" Opacity="0.75" TextWrapping="Wrap" />
                                        </StackPanel>

                                        <Border Margin="0,2,0,4" Padding="8,6" CornerRadius="6"
                                                Background="{DynamicResource MaterialDesignChipBackground}">
                                            <StackPanel Orientation="Horizontal">
                                                <materialDesign:PackIcon Kind="ShuffleVariant" Width="16" Height="16" VerticalAlignment="Top" Margin="0,1,6,0"
                                                                         Foreground="{DynamicResource PrimaryHueMidBrush}" />
                                                <TextBlock Text="{loc:Loc Adv.VideoSampling}" FontSize="11" Opacity="0.8" TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Border>

                                        <TextBlock Text="{loc:Loc Config.VideoSamples}" FontSize="12" Opacity="0.8" Margin="0,4,0,0" />
                                        <DockPanel>
                                            <TextBlock DockPanel.Dock="Right" MinWidth="46" TextAlignment="Center"
                                                       Text="{Binding VideoSamples}" VerticalAlignment="Center" />
                                            <Slider Minimum="2" Maximum="40" TickFrequency="1" IsSnapToTickEnabled="True"
                                                    Value="{Binding VideoSamples}" Margin="0,0,8,0" />
                                        </DockPanel>

                                        <Grid Margin="0,4,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="12" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="{loc:Loc Config.VideoIntroSkip}" FontSize="12" Opacity="0.8" />
                                                <DockPanel>
                                                    <TextBlock DockPanel.Dock="Right" MinWidth="34" TextAlignment="Center"
                                                               Text="{Binding VideoIntroSkip}" VerticalAlignment="Center" />
                                                    <Slider Minimum="0" Maximum="40" TickFrequency="1" IsSnapToTickEnabled="True"
                                                            Value="{Binding VideoIntroSkip}" Margin="0,0,6,0" />
                                                </DockPanel>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="{loc:Loc Config.VideoOutroSkip}" FontSize="12" Opacity="0.8" />
                                                <DockPanel>
                                                    <TextBlock DockPanel.Dock="Right" MinWidth="34" TextAlignment="Center"
                                                               Text="{Binding VideoOutroSkip}" VerticalAlignment="Center" />
                                                    <Slider Minimum="0" Maximum="40" TickFrequency="1" IsSnapToTickEnabled="True"
                                                            Value="{Binding VideoOutroSkip}" Margin="0,0,6,0" />
                                                </DockPanel>
                                            </StackPanel>
                                        </Grid>

                                        <TextBox Margin="0,10,0,0"
                                             IsEnabled="{Binding CanEditFfmpegPath}"
                                             materialDesign:HintAssist.Hint="{loc:Loc Config.Ffmpeg}"
                                             materialDesign:HintAssist.HelperText="ffmpeg + ffprobe"
                                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                             Text="{Binding FfmpegPath, UpdateSourceTrigger=PropertyChanged}" />

                                    <Button Margin="0,8,0,0" HorizontalAlignment="Stretch"
                                            Style="{StaticResource MaterialDesignOutlinedButton}"
                                            Command="{Binding DownloadFfmpegCommand}">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="Download" Margin="0,0,6,0" VerticalAlignment="Center" />
                                            <TextBlock Text="{loc:Loc Action.DownloadFfmpeg}" VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Button>
                                    <ProgressBar Margin="0,6,0,0" Height="5" Minimum="0" Maximum="100"
                                                 Value="{Binding FfmpegDownloadProgress, Mode=OneWay}"
                                                 Visibility="{Binding IsDownloadingFfmpeg, Converter={StaticResource BoolToVis}}" />
                                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                        <materialDesign:PackIcon VerticalAlignment="Center" Margin="0,0,4,0" Width="16" Height="16"
                                                                 Kind="CheckCircle"
                                                                 Foreground="{DynamicResource SecondaryHueMidBrush}"
                                                                 Visibility="{Binding FfmpegReady, Converter={StaticResource BoolToVis}}" />
                                        <TextBlock Text="{Binding FfmpegStatus}" FontSize="11" Opacity="0.75"
                                                   VerticalAlignment="Center" TextWrapping="Wrap" />
                                    </StackPanel>
                                    </StackPanel>
                                </StackPanel>

                                <Separator Margin="0,10" Opacity="0.4" />

                                <!-- Photo quality -->
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="ImageSearchOutline" VerticalAlignment="Center" Margin="0,0,6,0"
                                                                 Foreground="{DynamicResource PrimaryHueMidBrush}" />
                                        <TextBlock Text="{loc:Loc Adv.PhotoSection}" FontWeight="Medium" VerticalAlignment="Center" />
                                    </StackPanel>
                                    <TextBlock Text="{loc:Loc Adv.EnableHint}" FontSize="11" FontStyle="Italic" Opacity="0.7" TextWrapping="Wrap" Margin="0,2,0,0"
                                               Foreground="{DynamicResource PrimaryHueMidBrush}"
                                               Visibility="{Binding AnalyzePhotoQuality, Converter={StaticResource BoolToVis}, ConverterParameter=invert}" />
                                    <StackPanel IsEnabled="{Binding AnalyzePhotoQuality}">
                                        <TextBlock Text="{loc:Loc Adv.PhotoDesc}" FontSize="11" Opacity="0.6" TextWrapping="Wrap" Margin="0,2,0,2" />
                                        <StackPanel Orientation="Horizontal" Margin="0,1">
                                            <materialDesign:PackIcon Kind="CheckCircleOutline" Width="14" Height="14" VerticalAlignment="Center" Margin="0,0,4,0" Foreground="{DynamicResource SecondaryHueMidBrush}" />
                                            <TextBlock Text="{loc:Loc Adv.PhotoPro}" FontSize="11" Opacity="0.75" TextWrapping="Wrap" />
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,1,0,4">
                                            <materialDesign:PackIcon Kind="AlertCircleOutline" Width="14" Height="14" VerticalAlignment="Center" Margin="0,0,4,0" Foreground="#FFB300" />
                                            <TextBlock Text="{loc:Loc Adv.PhotoCon}" FontSize="11" Opacity="0.75" TextWrapping="Wrap" />
                                        </StackPanel>
                                        <TextBlock Text="{loc:Loc Config.BlurSensitivity}" FontSize="12" Opacity="0.8" Margin="0,4,0,0" />
                                        <DockPanel>
                                            <TextBlock DockPanel.Dock="Right" MinWidth="46" TextAlignment="Center"
                                                       Text="{Binding BlurThreshold, StringFormat={}{0:0}}" VerticalAlignment="Center" />
                                            <Slider Minimum="40" Maximum="300" TickFrequency="10" IsSnapToTickEnabled="True"
                                                    Value="{Binding BlurThreshold}" Margin="0,0,8,0" />
                                        </DockPanel>
                                    </StackPanel>
                                </StackPanel>

                                <Separator Margin="0,10" Opacity="0.4" />

                                <!-- Resource usage -->
                                <CheckBox IsChecked="{Binding GentleResourceUsage}" Margin="0,2">
                                    <StackPanel>
                                        <TextBlock Text="{loc:Loc Config.Gentle}" FontWeight="Medium" />
                                        <TextBlock Text="{loc:Loc Adv.GentleDesc}" FontSize="11" Opacity="0.6" TextWrapping="Wrap" />
                                    </StackPanel>
                                </CheckBox>
                            </StackPanel>
                        </materialDesign:Card>

                        <!-- Scan actions -->
                        <materialDesign:Card Style="{StaticResource Section}">
                            <StackPanel>
                                <Button Style="{StaticResource PrimaryAction}"
                                        Command="{Binding ScanCommand}"
                                        Visibility="{Binding IsScanning, Converter={StaticResource BoolToVis}, ConverterParameter=invert}">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="Magnify" Width="22" Height="22" Margin="0,0,8,0" VerticalAlignment="Center" />
                                        <TextBlock Text="{loc:Loc Action.Scan}" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                                <Button Height="46" Style="{StaticResource MaterialDesignOutlinedButton}"
                                        Command="{Binding CancelCommand}"
                                        Visibility="{Binding IsScanning, Converter={StaticResource BoolToVis}}">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="Close" Margin="0,0,6,0" VerticalAlignment="Center" />
                                        <TextBlock Text="{loc:Loc Action.Cancel}" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>

                                <ProgressBar Margin="0,14,0,6" Height="6"
                                             Value="{Binding ProgressValue, Mode=OneWay}"
                                             IsIndeterminate="{Binding IsIndeterminate}"
                                             Visibility="{Binding IsScanning, Converter={StaticResource BoolToVis}}" />
                                <TextBlock Text="{Binding StatusText}" FontWeight="Medium" />
                                <TextBlock Text="{Binding CurrentFile}" FontSize="11" Opacity="0.6"
                                           TextTrimming="CharacterEllipsis"
                                           Visibility="{Binding CurrentFile, Converter={StaticResource StringToVis}}" />
                            </StackPanel>
                        </materialDesign:Card>
                    </StackPanel>
                </ScrollViewer>

                <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Center"
                              VerticalAlignment="Stretch" Background="{DynamicResource MaterialDesignDivider}" />

                <!-- ===== Right: tabbed results ===== -->
                <TabControl Grid.Column="2" Margin="6,8,8,6" Padding="0"
                            Background="Transparent" BorderThickness="0">
                    <!-- ============ Tab: Duplicates ============ -->
                    <TabItem>
                        <TabItem.Header>
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="FileMultipleOutline" VerticalAlignment="Center" Margin="0,0,6,0" />
                                <TextBlock Text="{loc:Loc Tab.Duplicates}" VerticalAlignment="Center" />
                            </StackPanel>
                        </TabItem.Header>
                <Grid Margin="0,6,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Summary stat cards -->
                    <materialDesign:Card Grid.Row="0" Style="{StaticResource Section}">
                        <WrapPanel>
                            <Border Style="{StaticResource StatCard}">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="FileSearchOutline" Width="26" Height="26" VerticalAlignment="Center"
                                                             Margin="0,0,10,0" Foreground="{DynamicResource PrimaryHueMidBrush}" />
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource StatLabel}" Text="{loc:Loc Results.FilesScanned}" />
                                        <TextBlock Style="{StaticResource StatValue}" Text="{Binding FilesScanned}" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource StatCard}">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="FolderMultipleOutline" Width="26" Height="26" VerticalAlignment="Center"
                                                             Margin="0,0,10,0" Foreground="{DynamicResource PrimaryHueMidBrush}" />
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource StatLabel}" Text="{loc:Loc Results.Groups}" />
                                        <TextBlock Style="{StaticResource StatValue}" Text="{Binding GroupCount}" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource StatCard}">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="ContentDuplicate" Width="26" Height="26" VerticalAlignment="Center"
                                                             Margin="0,0,10,0" Foreground="{StaticResource WarnBrush}" />
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource StatLabel}" Text="{loc:Loc Results.RedundantFiles}" />
                                        <TextBlock Style="{StaticResource StatValue}" Text="{Binding RedundantCount}"
                                                   Foreground="{StaticResource WarnBrush}" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource StatCard}">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="DeleteSweepOutline" Width="26" Height="26" VerticalAlignment="Center"
                                                             Margin="0,0,10,0" Foreground="{DynamicResource SecondaryHueMidBrush}" />
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource StatLabel}" Text="{loc:Loc Results.Reclaimable}" />
                                        <TextBlock Style="{StaticResource StatValue}" Text="{Binding ReclaimableDisplay}"
                                                   Foreground="{DynamicResource SecondaryHueMidBrush}" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource StatCard}" MinWidth="120">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="TimerOutline" Width="26" Height="26" VerticalAlignment="Center"
                                                             Margin="0,0,10,0" Opacity="0.7" />
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource StatLabel}" Text="{loc:Loc Results.Elapsed}" />
                                        <TextBlock Style="{StaticResource StatValue}" Text="{Binding ElapsedDisplay}" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </WrapPanel>
                    </materialDesign:Card>

                    <!-- Result toolbar -->
                    <materialDesign:Card Grid.Row="1" Style="{StaticResource Section}">
                        <WrapPanel>
                            <TextBlock Text="{loc:Loc Keep.Rule}" VerticalAlignment="Center" Margin="0,0,8,0" />
                            <ComboBox MinWidth="150" Margin="0,0,8,0" VerticalAlignment="Center"
                                      ItemsSource="{Binding KeepRules}"
                                      SelectedItem="{Binding SelectedKeepRule}"
                                      DisplayMemberPath="Display" />
                            <Button Style="{StaticResource MaterialDesignRaisedSecondaryButton}" Margin="0,0,8,0"
                                    Command="{Binding AutoSelectCommand}" Content="{loc:Loc Action.SelectByRule}" />
                            <Button Style="{StaticResource MaterialDesignOutlinedButton}" Margin="0,0,8,0"
                                    Command="{Binding ClearSelectionCommand}" Content="{loc:Loc Action.ClearSelection}" />
                            <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="4,0" />
                            <Button Style="{StaticResource MaterialDesignFlatButton}" Margin="0,0,4,0"
                                    Command="{Binding ExpandAllCommand}" Content="{loc:Loc Action.ExpandAll}" />
                            <Button Style="{StaticResource MaterialDesignFlatButton}" Margin="0,0,4,0"
                                    Command="{Binding CollapseAllCommand}" Content="{loc:Loc Action.CollapseAll}" />
                            <Button Style="{StaticResource MaterialDesignFlatButton}" Margin="0,0,4,0"
                                    Command="{Binding ExportCsvCommand}" Content="{loc:Loc Action.ExportCsv}" />
                            <Button Style="{StaticResource MaterialDesignFlatButton}"
                                    Command="{Binding ExportJsonCommand}" Content="{loc:Loc Action.ExportJson}" />
                            <TextBox MinWidth="200" Margin="8,0,0,0" VerticalAlignment="Center"
                                     materialDesign:HintAssist.Hint="{loc:Loc Action.Search}"
                                     materialDesign:TextFieldAssist.HasClearButton="True"
                                     materialDesign:TextFieldAssist.HasLeadingIcon="True"
                                     materialDesign:TextFieldAssist.LeadingIcon="Magnify"
                                     Style="{StaticResource MaterialDesignFilledTextBox}"
                                     Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged, Delay=200}" />
                        </WrapPanel>
                    </materialDesign:Card>

                    <!-- Result groups -->
                    <Grid Grid.Row="2" Margin="8,0">
                        <!-- Empty states -->
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                                    Visibility="{Binding HasScanned, Converter={StaticResource BoolToVis}, ConverterParameter=invert}">
                            <materialDesign:PackIcon Kind="FolderSearchOutline" Width="72" Height="72"
                                                     HorizontalAlignment="Center" Opacity="0.3" />
                            <TextBlock Text="{loc:Loc Results.NoResults}" Opacity="0.5" Margin="0,10,0,0"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding HasScanned}" Value="True" />
                                                <Condition Binding="{Binding HasResults}" Value="False" />
                                                <Condition Binding="{Binding IsScanning}" Value="False" />
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="Visibility" Value="Visible" />
                                        </MultiDataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <materialDesign:PackIcon Kind="CheckCircleOutline" Width="72" Height="72"
                                                     HorizontalAlignment="Center" Opacity="0.4"
                                                     Foreground="{DynamicResource SecondaryHueMidBrush}" />
                            <TextBlock Text="{loc:Loc Results.NoDuplicates}" Opacity="0.6" Margin="0,10,0,0"
                                       HorizontalAlignment="Center" />
                        </StackPanel>

                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      Visibility="{Binding HasResults, Converter={StaticResource BoolToVis}}">
                            <ItemsControl ItemsSource="{Binding Groups}">
                                <ItemsControl.ItemContainerStyle>
                                    <Style TargetType="ContentPresenter">
                                        <Setter Property="Visibility"
                                                Value="{Binding IsVisible, Converter={StaticResource BoolToVis}}" />
                                    </Style>
                                </ItemsControl.ItemContainerStyle>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type vm:DuplicateGroupViewModel}">
                                        <materialDesign:Card Margin="0,6" UniformCornerRadius="8"
                                                             materialDesign:ElevationAssist.Elevation="Dp2">
                                            <Expander IsExpanded="{Binding IsExpanded}" Background="Transparent">
                                                <Expander.Header>
                                                    <WrapPanel Margin="4,4">
                                                        <materialDesign:Chip Content="{Binding MethodDisplay}" Margin="0,0,8,0"
                                                                             FontSize="11" />
                                                        <TextBlock VerticalAlignment="Center" Margin="0,0,12,0">
                                                            <Run Text="{loc:Loc Results.Group}" />
                                                            <Run Text="{Binding Index}" FontWeight="Bold" />
                                                        </TextBlock>
                                                        <TextBlock VerticalAlignment="Center" Margin="0,0,12,0" Opacity="0.8">
                                                            <Run Text="{Binding Count, Mode=OneWay}" FontWeight="Bold" />
                                                            <Run Text="×" />
                                                        </TextBlock>
                                                        <materialDesign:PackIcon Kind="Percent" VerticalAlignment="Center"
                                                                                 Width="14" Height="14" Opacity="0.6" />
                                                        <TextBlock Text="{Binding SimilarityDisplay}" VerticalAlignment="Center"
                                                                   Margin="0,0,12,0" Opacity="0.8" />
                                                        <materialDesign:PackIcon Kind="DeleteSweepOutline" VerticalAlignment="Center"
                                                                                 Width="16" Height="16" Opacity="0.6" Margin="0,0,4,0" />
                                                        <TextBlock VerticalAlignment="Center"
                                                                   Text="{Binding ReclaimableBytes, Converter={StaticResource ByteSize}}"
                                                                   Foreground="{DynamicResource SecondaryHueMidBrush}" />
                                                        <Button Style="{StaticResource MaterialDesignIconButton}"
                                                                Width="28" Height="28" Padding="0" Margin="10,0,0,0"
                                                                ToolTip="{loc:Loc Ctx.SelectRedundant}"
                                                                Command="{Binding DataContext.SelectGroupRedundantCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                CommandParameter="{Binding}">
                                                            <materialDesign:PackIcon Kind="SelectMultiple" Width="16" Height="16" />
                                                        </Button>
                                                        <Button Style="{StaticResource MaterialDesignIconButton}"
                                                                Width="28" Height="28" Padding="0"
                                                                ToolTip="{loc:Loc Ctx.ClearGroup}"
                                                                Command="{Binding DataContext.ClearGroupSelectionCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                CommandParameter="{Binding}">
                                                            <materialDesign:PackIcon Kind="SelectOff" Width="16" Height="16" />
                                                        </Button>
                                                    </WrapPanel>
                                                </Expander.Header>

                                                <DataGrid ItemsSource="{Binding Files}"
                                                          Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}"
                                                          AutoGenerateColumns="False"
                                                          CanUserAddRows="False"
                                                          CanUserDeleteRows="False"
                                                          HeadersVisibility="Column"
                                                          IsReadOnly="False"
                                                          SelectionMode="Extended"
                                                          GridLinesVisibility="None"
                                                          materialDesign:DataGridAssist.CellPadding="10,6"
                                                          materialDesign:DataGridAssist.ColumnHeaderPadding="10,8"
                                                          Margin="8,0,8,10">
                                                    <DataGrid.Columns>
                                                        <DataGridCheckBoxColumn Header="{loc:Loc Grid.Keep}"
                                                                                Binding="{Binding IsMarkedForRemoval, UpdateSourceTrigger=PropertyChanged}"
                                                                                Width="Auto" />
                                                        <DataGridTemplateColumn Header="{loc:Loc Grid.Preview}" Width="Auto">
                                                            <DataGridTemplateColumn.CellTemplate>
                                                                <DataTemplate>
                                                                    <Border Width="56" Height="40" CornerRadius="4" Margin="0,2"
                                                                            Background="{DynamicResource MaterialDesignChipBackground}" ClipToBounds="True">
                                                                        <ctrl:AsyncThumbnail DecodeWidth="120"
                                                                                             MediaPath="{Binding FullPath}"
                                                                                             MediaExtension="{Binding Extension}" />
                                                                    </Border>
                                                                </DataTemplate>
                                                            </DataGridTemplateColumn.CellTemplate>
                                                        </DataGridTemplateColumn>
                                                        <DataGridTemplateColumn Header="{loc:Loc Grid.File}" Width="2*"
                                                                                SortMemberPath="FileName">
                                                            <DataGridTemplateColumn.CellTemplate>
                                                                <DataTemplate>
                                                                    <StackPanel Orientation="Horizontal">
                                                                        <materialDesign:PackIcon Kind="ImageOutline" VerticalAlignment="Center"
                                                                                                 Margin="0,0,6,0" Opacity="0.7"
                                                                                                 Visibility="{Binding IsImage, Converter={StaticResource BoolToVis}}" />
                                                                        <materialDesign:PackIcon Kind="FileOutline" VerticalAlignment="Center"
                                                                                                 Margin="0,0,6,0" Opacity="0.5"
                                                                                                 Visibility="{Binding IsImage, Converter={StaticResource BoolToVis}, ConverterParameter=invert}" />
                                                                        <TextBlock Text="{Binding FileName}" VerticalAlignment="Center"
                                                                                   TextTrimming="CharacterEllipsis" />
                                                                        <StackPanel.ToolTip>
                                                                            <ToolTip>
                                                                                <StackPanel MaxWidth="260">
                                                                                    <Image Stretch="Uniform" MaxHeight="180" Margin="0,0,0,6"
                                                                                           Source="{Binding FullPath, Converter={StaticResource Thumbnail}}"
                                                                                           Visibility="{Binding IsImage, Converter={StaticResource BoolToVis}}" />
                                                                                    <TextBlock Text="{Binding FullPath}" TextWrapping="Wrap" FontSize="11" />
                                                                                </StackPanel>
                                                                            </ToolTip>
                                                                        </StackPanel.ToolTip>
                                                                    </StackPanel>
                                                                </DataTemplate>
                                                            </DataGridTemplateColumn.CellTemplate>
                                                        </DataGridTemplateColumn>
                                                        <DataGridTextColumn Header="{loc:Loc Grid.Folder}"
                                                                            Binding="{Binding DirectoryName}" Width="3*" />
                                                        <DataGridTextColumn Header="{loc:Loc Grid.Size}"
                                                                            Binding="{Binding Length, Converter={StaticResource ByteSize}}"
                                                                            Width="Auto" />
                                                        <DataGridTextColumn Header="{loc:Loc Grid.Modified}"
                                                                            Binding="{Binding LastWriteUtc, Converter={StaticResource UtcToLocal}}"
                                                                            Width="Auto" />
                                                        <DataGridTemplateColumn Width="Auto">
                                                            <DataGridTemplateColumn.CellTemplate>
                                                                <DataTemplate>
                                                                    <Button Style="{StaticResource MaterialDesignIconButton}"
                                                                            Width="28" Height="28" Padding="0"
                                                                            ToolTip="{loc:Loc Action.OpenFolder}"
                                                                            Command="{Binding DataContext.OpenLocationCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                            CommandParameter="{Binding}">
                                                                        <materialDesign:PackIcon Kind="FolderOpenOutline" Width="16" Height="16" />
                                                                    </Button>
                                                                </DataTemplate>
                                                            </DataGridTemplateColumn.CellTemplate>
                                                        </DataGridTemplateColumn>
                                                    </DataGrid.Columns>
                                                    <DataGrid.RowStyle>
                                                        <Style TargetType="DataGridRow" BasedOn="{StaticResource MaterialDesignDataGridRow}">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsMarkedForRemoval}" Value="True">
                                                                    <Setter Property="Background" Value="#1FE53935" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </DataGrid.RowStyle>
                                                    <DataGrid.ContextMenu>
                                                        <ContextMenu>
                                                            <MenuItem Header="{loc:Loc Ctx.Open}"
                                                                      Command="{Binding PlacementTarget.Tag.OpenFileCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                      CommandParameter="{Binding PlacementTarget.SelectedItem, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                                                                <MenuItem.Icon><materialDesign:PackIcon Kind="FileOutline" /></MenuItem.Icon>
                                                            </MenuItem>
                                                            <MenuItem Header="{loc:Loc Ctx.OpenLocation}"
                                                                      Command="{Binding PlacementTarget.Tag.OpenLocationCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                      CommandParameter="{Binding PlacementTarget.SelectedItem, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                                                                <MenuItem.Icon><materialDesign:PackIcon Kind="FolderOpenOutline" /></MenuItem.Icon>
                                                            </MenuItem>
                                                            <Separator />
                                                            <MenuItem Header="{loc:Loc Ctx.CopyPath}"
                                                                      Command="{Binding PlacementTarget.Tag.CopyPathCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                      CommandParameter="{Binding PlacementTarget.SelectedItem, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                                                                <MenuItem.Icon><materialDesign:PackIcon Kind="ContentCopy" /></MenuItem.Icon>
                                                            </MenuItem>
                                                            <MenuItem Header="{loc:Loc Ctx.CopyFolder}"
                                                                      Command="{Binding PlacementTarget.Tag.CopyFolderCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                      CommandParameter="{Binding PlacementTarget.SelectedItem, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                                        </ContextMenu>
                                                    </DataGrid.ContextMenu>
                                                </DataGrid>
                                            </Expander>
                                        </materialDesign:Card>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>

                    <!-- Bottom action bar -->
                    <materialDesign:Card Grid.Row="3" Style="{StaticResource Section}"
                                         Visibility="{Binding HasResults, Converter={StaticResource BoolToVis}}">
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                                <materialDesign:PackIcon Kind="CheckboxMarkedCircleOutline" VerticalAlignment="Center" Margin="0,0,6,0" />
                                <TextBlock VerticalAlignment="Center">
                                    <Run Text="{loc:Loc Results.Selected}" />
                                    <Run Text=": " />
                                    <Run Text="{Binding SelectedCount, Mode=OneWay}" FontWeight="Bold" />
                                    <Run Text=" (" /><Run Text="{Binding SelectedSizeDisplay, Mode=OneWay}" FontWeight="Bold" /><Run Text=")" />
                                </TextBlock>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Style="{StaticResource MaterialDesignOutlinedButton}" Margin="0,0,8,0"
                                        materialDesign:ButtonAssist.CornerRadius="8"
                                        Command="{Binding MoveCommand}">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="FolderMoveOutline" Margin="0,0,6,0" VerticalAlignment="Center" />
                                        <TextBlock Text="{loc:Loc Action.MoveTo}" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                                <Button Style="{StaticResource MaterialDesignRaisedButton}" Margin="0,0,8,0"
                                        materialDesign:ButtonAssist.CornerRadius="8"
                                        Command="{Binding RecycleCommand}">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="DeleteOutline" Margin="0,0,6,0" VerticalAlignment="Center" />
                                        <TextBlock Text="{loc:Loc Action.Recycle}" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                                <Button Command="{Binding DeleteCommand}"
                                        Background="{StaticResource DangerBrush}" BorderBrush="{StaticResource DangerBrush}"
                                        materialDesign:ButtonAssist.CornerRadius="8"
                                        Style="{StaticResource MaterialDesignRaisedButton}">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="DeleteForeverOutline" Margin="0,0,6,0" VerticalAlignment="Center" />
                                        <TextBlock Text="{loc:Loc Action.DeletePermanently}" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </DockPanel>
                    </materialDesign:Card>
                </Grid>
                    </TabItem>

                    <!-- ============ Tab: Photo Cleanup ============ -->
                    <TabItem>
                        <TabItem.Header>
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="ImageSearchOutline" VerticalAlignment="Center" Margin="0,0,6,0" />
                                <TextBlock Text="{loc:Loc Tab.PhotoCleanup}" VerticalAlignment="Center" />
                            </StackPanel>
                        </TabItem.Header>
                        <Grid Margin="0,6,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <!-- Photo toolbar -->
                            <materialDesign:Card Grid.Row="0" Style="{StaticResource Section}">
                                <WrapPanel VerticalAlignment="Center">
                                    <CheckBox Content="{loc:Loc Photo.ShowOnlyFlagged}" IsChecked="{Binding ShowOnlyFlaggedPhotos}"
                                              VerticalAlignment="Center" Margin="0,0,12,0" />
                                    <Button Style="{StaticResource MaterialDesignRaisedSecondaryButton}" Margin="0,0,8,0"
                                            Command="{Binding SelectFlaggedPhotosCommand}" Content="{loc:Loc Photo.SelectFlagged}" />
                                    <Button Style="{StaticResource MaterialDesignOutlinedButton}" Margin="0,0,12,0"
                                            Command="{Binding ClearPhotoSelectionCommand}" Content="{loc:Loc Action.ClearSelection}" />
                                    <TextBlock VerticalAlignment="Center" Opacity="0.8">
                                        <Run Text="{Binding PhotoIssues.Count, Mode=OneWay}" FontWeight="Bold" />
                                        <Run Text="{loc:Loc Photo.Analyzed}" />
                                        <Run Text="  ·  " />
                                        <Run Text="{Binding FlaggedPhotoCount, Mode=OneWay}" FontWeight="Bold" Foreground="#F59E0B" />
                                        <Run Text="{loc:Loc Photo.Flagged}" />
                                    </TextBlock>
                                </WrapPanel>
                            </materialDesign:Card>

                            <!-- Empty state -->
                            <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center"
                                        Visibility="{Binding HasPhotos, Converter={StaticResource BoolToVis}, ConverterParameter=invert}">
                                <materialDesign:PackIcon Kind="ImageSearchOutline" Width="72" Height="72" HorizontalAlignment="Center" Opacity="0.3" />
                                <TextBlock Text="{loc:Loc Photo.NoPhotos}" Opacity="0.55" Margin="0,10,0,0" MaxWidth="360"
                                           TextWrapping="Wrap" TextAlignment="Center" HorizontalAlignment="Center" />
                            </StackPanel>

                            <!-- Photo list -->
                            <materialDesign:Card Grid.Row="1" Style="{StaticResource Section}"
                                                 Visibility="{Binding HasPhotos, Converter={StaticResource BoolToVis}}">
                                <DataGrid ItemsSource="{Binding PhotosView}"
                                          Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}"
                                          AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False"
                                          HeadersVisibility="Column" IsReadOnly="False" SelectionMode="Extended"
                                          GridLinesVisibility="None" RowHeight="60"
                                          materialDesign:DataGridAssist.CellPadding="10,4"
                                          materialDesign:DataGridAssist.ColumnHeaderPadding="10,8">
                                    <DataGrid.Columns>
                                        <DataGridCheckBoxColumn Binding="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}" Width="Auto" />
                                        <DataGridTemplateColumn Header="{loc:Loc Grid.Preview}" Width="Auto">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Border Width="80" Height="52" CornerRadius="6" Margin="0,3"
                                                            Background="{DynamicResource MaterialDesignChipBackground}" ClipToBounds="True">
                                                        <Border.ToolTip>
                                                            <ToolTip>
                                                                <ctrl:AsyncThumbnail DecodeWidth="420" Width="320"
                                                                                     MediaPath="{Binding FullPath}" MediaExtension="{Binding Extension}" />
                                                            </ToolTip>
                                                        </Border.ToolTip>
                                                        <ctrl:AsyncThumbnail DecodeWidth="180"
                                                                             MediaPath="{Binding FullPath}" MediaExtension="{Binding Extension}" />
                                                    </Border>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTextColumn Header="{loc:Loc Grid.File}" Binding="{Binding FileName}" Width="2*" />
                                        <DataGridTextColumn Header="{loc:Loc Grid.Folder}" Binding="{Binding DirectoryName}" Width="3*" />
                                        <DataGridTextColumn Header="{loc:Loc Grid.Resolution}" Binding="{Binding Resolution}" Width="Auto" />
                                        <DataGridTextColumn Header="{loc:Loc Grid.Size}"
                                                            Binding="{Binding Length, Converter={StaticResource ByteSize}}" Width="Auto" />
                                        <DataGridTemplateColumn Header="{loc:Loc Grid.Score}" Width="Auto">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding Score}" FontWeight="Bold" HorizontalAlignment="Center" />
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTextColumn Header="{loc:Loc Grid.Issues}" Binding="{Binding FlagsText}" Width="Auto" />
                                        <DataGridTemplateColumn Width="Auto">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Button Style="{StaticResource MaterialDesignIconButton}" Width="28" Height="28" Padding="0"
                                                            ToolTip="{loc:Loc Action.OpenFolder}"
                                                            Command="{Binding DataContext.OpenPhotoLocationCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            CommandParameter="{Binding}">
                                                        <materialDesign:PackIcon Kind="FolderOpenOutline" Width="16" Height="16" />
                                                    </Button>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                    <DataGrid.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="{loc:Loc Ctx.Open}"
                                                      Command="{Binding PlacementTarget.Tag.OpenPhotoCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      CommandParameter="{Binding PlacementTarget.SelectedItem, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                            <MenuItem Header="{loc:Loc Ctx.OpenLocation}"
                                                      Command="{Binding PlacementTarget.Tag.OpenPhotoLocationCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      CommandParameter="{Binding PlacementTarget.SelectedItem, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                            <MenuItem Header="{loc:Loc Ctx.CopyPath}"
                                                      Command="{Binding PlacementTarget.Tag.CopyPhotoPathCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      CommandParameter="{Binding PlacementTarget.SelectedItem, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                        </ContextMenu>
                                    </DataGrid.ContextMenu>
                                </DataGrid>
                            </materialDesign:Card>

                            <!-- Photo bottom action bar -->
                            <materialDesign:Card Grid.Row="2" Style="{StaticResource Section}"
                                                 Visibility="{Binding HasPhotos, Converter={StaticResource BoolToVis}}">
                                <DockPanel>
                                    <TextBlock DockPanel.Dock="Left" VerticalAlignment="Center">
                                        <Run Text="{loc:Loc Results.Selected}" />
                                        <Run Text=": " />
                                        <Run Text="{Binding SelectedPhotoCount, Mode=OneWay}" FontWeight="Bold" />
                                        <Run Text=" (" /><Run Text="{Binding SelectedPhotoSizeDisplay, Mode=OneWay}" FontWeight="Bold" /><Run Text=")" />
                                    </TextBlock>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                        <Button Style="{StaticResource MaterialDesignOutlinedButton}" Margin="0,0,8,0"
                                                materialDesign:ButtonAssist.CornerRadius="8"
                                                Command="{Binding MovePhotosCommand}" Content="{loc:Loc Action.MoveTo}" />
                                        <Button Style="{StaticResource MaterialDesignRaisedButton}" Margin="0,0,8,0"
                                                materialDesign:ButtonAssist.CornerRadius="8"
                                                Command="{Binding RecyclePhotosCommand}" Content="{loc:Loc Action.Recycle}" />
                                        <Button Command="{Binding DeletePhotosCommand}"
                                                Background="{StaticResource DangerBrush}" BorderBrush="{StaticResource DangerBrush}"
                                                materialDesign:ButtonAssist.CornerRadius="8"
                                                Style="{StaticResource MaterialDesignRaisedButton}"
                                                Content="{loc:Loc Action.DeletePermanently}" />
                                    </StackPanel>
                                </DockPanel>
                            </materialDesign:Card>
                        </Grid>
                    </TabItem>

                    <!-- ============ Tab: Statistics ============ -->
                    <TabItem>
                        <TabItem.Header>
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="ChartBoxOutline" VerticalAlignment="Center" Margin="0,0,6,0" />
                                <TextBlock Text="{loc:Loc Tab.Statistics}" VerticalAlignment="Center" />
                            </StackPanel>
                        </TabItem.Header>
                        <Grid Margin="0,6,0,0">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                                        Visibility="{Binding HasStatistics, Converter={StaticResource BoolToVis}, ConverterParameter=invert}">
                                <materialDesign:PackIcon Kind="ChartBoxOutline" Width="72" Height="72" HorizontalAlignment="Center" Opacity="0.3" />
                                <TextBlock Text="{loc:Loc Stat.NoStats}" Opacity="0.55" Margin="0,10,0,0" HorizontalAlignment="Center" />
                            </StackPanel>

                            <ScrollViewer VerticalScrollBarVisibility="Auto"
                                          Visibility="{Binding HasStatistics, Converter={StaticResource BoolToVis}}">
                                <StackPanel>
                                    <!-- Overview -->
                                    <materialDesign:Card Style="{StaticResource Section}">
                                        <StackPanel>
                                            <StackPanel Style="{StaticResource SectionHeader}">
                                                <Border Style="{StaticResource AccentBar}" />
                                                <TextBlock Style="{StaticResource SectionTitle}" Text="{loc:Loc Stat.Overview}" />
                                            </StackPanel>
                                            <WrapPanel>
                                                <Border Style="{StaticResource StatCard}">
                                                    <StackPanel>
                                                        <TextBlock Style="{StaticResource StatLabel}" Text="{loc:Loc Results.FilesScanned}" />
                                                        <TextBlock Style="{StaticResource StatValue}" Text="{Binding FilesScanned}" />
                                                    </StackPanel>
                                                </Border>
                                                <Border Style="{StaticResource StatCard}">
                                                    <StackPanel>
                                                        <TextBlock Style="{StaticResource StatLabel}" Text="{loc:Loc Stat.BytesScanned}" />
                                                        <TextBlock Style="{StaticResource StatValue}" Text="{Binding BytesScannedDisplay}" />
                                                    </StackPanel>
                                                </Border>
                                                <Border Style="{StaticResource StatCard}">
                                                    <StackPanel>
                                                        <TextBlock Style="{StaticResource StatLabel}" Text="{loc:Loc Results.RedundantFiles}" />
                                                        <TextBlock Style="{StaticResource StatValue}" Text="{Binding RedundantCount}" Foreground="{StaticResource WarnBrush}" />
                                                    </StackPanel>
                                                </Border>
                                                <Border Style="{StaticResource StatCard}">
                                                    <StackPanel>
                                                        <TextBlock Style="{StaticResource StatLabel}" Text="{loc:Loc Results.Reclaimable}" />
                                                        <TextBlock Style="{StaticResource StatValue}" Text="{Binding ReclaimableDisplay}" Foreground="{DynamicResource SecondaryHueMidBrush}" />
                                                    </StackPanel>
                                                </Border>
                                                <Border Style="{StaticResource StatCard}">
                                                    <StackPanel>
                                                        <TextBlock Style="{StaticResource StatLabel}" Text="{loc:Loc Photo.Flagged}" />
                                                        <TextBlock Style="{StaticResource StatValue}" Text="{Binding FlaggedPhotoCount}" />
                                                    </StackPanel>
                                                </Border>
                                            </WrapPanel>
                                        </StackPanel>
                                    </materialDesign:Card>

                                    <!-- Size by type -->
                                    <materialDesign:Card Style="{StaticResource Section}"
                                                         Visibility="{Binding FileTypeBars.Count, Converter={StaticResource CountToVis}}">
                                        <StackPanel>
                                            <StackPanel Style="{StaticResource SectionHeader}">
                                                <Border Style="{StaticResource AccentBar}" />
                                                <TextBlock Style="{StaticResource SectionTitle}" Text="{loc:Loc Stat.ByType}" />
                                            </StackPanel>
                                            <ItemsControl ItemsSource="{Binding FileTypeBars}" ItemTemplate="{StaticResource StatBarTemplate}" />
                                        </StackPanel>
                                    </materialDesign:Card>

                                    <!-- Reclaimable by method -->
                                    <materialDesign:Card Style="{StaticResource Section}"
                                                         Visibility="{Binding MethodBars.Count, Converter={StaticResource CountToVis}}">
                                        <StackPanel>
                                            <StackPanel Style="{StaticResource SectionHeader}">
                                                <Border Style="{StaticResource AccentBar}" />
                                                <TextBlock Style="{StaticResource SectionTitle}" Text="{loc:Loc Stat.ByMethod}" />
                                            </StackPanel>
                                            <ItemsControl ItemsSource="{Binding MethodBars}" ItemTemplate="{StaticResource StatBarTemplate}" />
                                        </StackPanel>
                                    </materialDesign:Card>

                                    <!-- Photo quality breakdown -->
                                    <materialDesign:Card Style="{StaticResource Section}"
                                                         Visibility="{Binding PhotoFlagBars.Count, Converter={StaticResource CountToVis}}">
                                        <StackPanel>
                                            <StackPanel Style="{StaticResource SectionHeader}">
                                                <Border Style="{StaticResource AccentBar}" />
                                                <TextBlock Style="{StaticResource SectionTitle}" Text="{loc:Loc Stat.PhotoQuality}" />
                                            </StackPanel>
                                            <ItemsControl ItemsSource="{Binding PhotoFlagBars}" ItemTemplate="{StaticResource StatBarTemplate}" />
                                        </StackPanel>
                                    </materialDesign:Card>

                                    <!-- Largest groups -->
                                    <materialDesign:Card Style="{StaticResource Section}"
                                                         Visibility="{Binding TopGroups.Count, Converter={StaticResource CountToVis}}">
                                        <StackPanel>
                                            <StackPanel Style="{StaticResource SectionHeader}">
                                                <Border Style="{StaticResource AccentBar}" />
                                                <TextBlock Style="{StaticResource SectionTitle}" Text="{loc:Loc Stat.TopGroups}" />
                                            </StackPanel>
                                            <ItemsControl ItemsSource="{Binding TopGroups}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate DataType="{x:Type vm:DuplicateGroupViewModel}">
                                                        <Grid Margin="0,4">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto" />
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="Auto" />
                                                            </Grid.ColumnDefinitions>
                                                            <materialDesign:Chip Grid.Column="0" Content="{Binding MethodDisplay}" FontSize="11" Margin="0,0,10,0" />
                                                            <TextBlock Grid.Column="1" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"
                                                                       Text="{Binding Files[0].FileName}" ToolTip="{Binding Files[0].FullPath}" />
                                                            <TextBlock Grid.Column="2" VerticalAlignment="Center" FontWeight="Bold"
                                                                       Foreground="{DynamicResource SecondaryHueMidBrush}"
                                                                       Text="{Binding ReclaimableBytes, Converter={StaticResource ByteSize}}" />
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </materialDesign:Card>
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>
                    </TabItem>
                </TabControl>
            </Grid>
        </Grid>
    </materialDesign:DialogHost>
</Window>
